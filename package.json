{
  "name": "gp",
  "version": "1.0.0",
  "description": "Online Course Website - JSP + TypeScript frontend",
  "private": true,
  "scripts": {
    "build:ts": "tsc",
    "watch:ts": "tsc --watch",
    "build:bundle": "esbuild src/main/webapp/ts/index.ts --bundle --outdir=src/main/webapp/js --format=iife --sourcemap",
    "watch:bundle": "esbuild src/main/webapp/ts/index.ts --bundle --outdir=src/main/webapp/js --format=iife --sourcemap --watch",
    "build": "npm run build:ts && npm run build:bundle"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "esbuild": "^0.20.0",
    "@types/node": "^20.0.0"
  }
}
