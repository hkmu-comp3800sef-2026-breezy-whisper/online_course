{
  "name": "gp",
  "version": "1.0.0",
  "description": "Online Course Website - JSP + TypeScript frontend",
  "private": true,
  "scripts": {
    "build:ts": "tsc",
    "watch:ts": "tsc --watch",
    "build:bundle": "esbuild src/main/webapp/ts/**/*.ts --bundle --outdir=src/main/webapp/js --format=iife --sourcemap",
    "watch:bundle": "esbuild src/main/webapp/ts/**/*.ts --bundle --outdir=src/main/webapp/js --format=iife --sourcemap --watch",
    "build": "npm run build:ts && npm run build:bundle"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "esbuild": "^0.28.0",
    "@types/node": "^25.5.2"
  }
}
